# Proxy port (external)
MIMOCODE_PROXY_PORT=10000

# MiMo server port (internal)
MIMOCODE_SERVER_PORT=10001

# Proxy API key (leave empty to disable auth)
API_KEY=

# MiMo server password (leave empty to disable backend auth)
MIMOCODE_SERVER_PASSWORD=

# Disable tools (recommended for API-only use)
DISABLE_TOOLS=true

# Debug mode
MIMOCODE_PROXY_DEBUG=false

# Request timeout (ms)
MIMOCODE_PROXY_REQUEST_TIMEOUT_MS=180000

# PUID/PGID for Docker
PUID=1000
PGID=1000
